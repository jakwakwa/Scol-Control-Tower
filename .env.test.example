# =============================================================================
# .env.test — copy to `.env.test` (gitignored). Test DB + Clerk **AM/RM** users only.
# =============================================================================
#
# Turso (dedicated test DB only):
#   turso db create stratcol-onboard-test
#   turso db tokens create stratcol-onboard-test
#   turso db show stratcol-onboard-test --url   → TEST_DATABASE_URL
#
# Clerk app keys: keep in `.env.local` (see `.env.example`). Browser-flow loads
# `.env.test` then `.env.local` with **local winning**.
#
# | Flow                         | .env.test | .env.local |
# |------------------------------|-----------|------------|
# | test:e2e                     | yes       | no         |
# | dev:browser-flow, test:browser:* | yes   | yes (Clerk) |
# | db:push:test, db:migrate:test, test:db:reset, db:reset (test half) | yes | no |
#
# -----------------------------------------------------------------------------
# Test database (Playwright, dev:browser-flow migrate, reset, seed, E2E_USE_TEST_DB)
# -----------------------------------------------------------------------------
TEST_DATABASE_URL=
TEST_TURSO_GROUP_AUTH_TOKEN=

# -----------------------------------------------------------------------------
# Clerk sign-in: Account Manager + Risk Manager (browser-flow + preflight)
# -----------------------------------------------------------------------------
# If `E2E_CLERK_AM_*` is empty, stages 1–3 and preflight use `E2E_CLERK_RISKMANAGER_*`
# for the AM login (single test user). Prefer two real users when exercising roles.
E2E_CLERK_AM_USERNAME=
E2E_CLERK_AM_PASSWORD=

E2E_CLERK_RISKMANAGER_USERNAME=
E2E_CLERK_RISKMANAGER_PASSWORD=
# Alias accepted by some scripts:
# E2E_CLERK_RISK_MANAGER_USERNAME=
# E2E_CLERK_RISK_MANAGER_PASSWORD=

# -----------------------------------------------------------------------------
# Playwright (`bun run test:e2e`) — same `TEST_*` + AM/RM above; only `.env.test` is loaded.
# -----------------------------------------------------------------------------

# Optional: apply tracked migrations to test DB (parity with prod); push above is the supported test path.
# bun run db:migrate:test

# Optional: Turso CLI labels only (app uses URL + group token)
# TEST_TURSO_DATABASE_NAME=
# TEST_TURSO_API_TOKEN=

# Optional: browser-flow app URL (default http://localhost:3100)
# BROWSER_FLOW_PORT=3100
# BROWSER_FLOW_BASE_URL=http://localhost:3100
# BROWSER_FLOW_SEED_TARGET=test

# Optional: Playwright web server
# PW_WEB_SERVER_PORT=3001

# Optional
# RUN_SLOW_WORKFLOW_TEST=1
# PLAYWRIGHT_TEST_SECRET=
# BYPASS_INITIAL_REAPPLICANT_TEST=true

# -----------------------------------------------------------------------------
# ProcureCheck PDF verify seed (`scripts/seed-procurecheck-verify.ts`, verify-refactor).
# Fill in `.env.test` with your xdev sandbox vendor — do not commit real reg/VAT values.
# -----------------------------------------------------------------------------
E2E_PROCURECHECK_REUSE_VENDOR=
PROCURECHECK_VERIFICATION_VENDOR_ID=
PROCURECHECK_VERIFICATION_VENDOR_GUID=
PROCURECHECK_VERIFICATION_REG_NO=
PROCURECHECK_VERIFICATION_VAT_NO=
