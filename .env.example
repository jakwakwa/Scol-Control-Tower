# Create a new Clerk webhook (user.created event) with your app URL and append /webhooks/clerk 
# turso auth api-tokens mint clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
TURSO_API_TOKEN=
# your personal or organization name
TURSO_ORG="control-group"
FIRECRAWL_API_KEY=
# turso db create [database-name]
TURSO_DATABASE_NAME=
DATABASE_URL=
TURSO_GROUP_AUTH_TOKEN=
# deployed inngest env
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
# Public URL for callbacks (use ngrok for local dev)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NGROK_AUTH_TOKEN=
NGROK_API_KEY=
GOOGLE_GENAI_KEY=
E2E_CLERK_USER_USERNAME=
E2E_CLERK_USER_EMAIL="work+clerk_test@example.com"
E2E_CLERK_USER_PASSWORD=    
RESEND_API_KEY=
ALERT_EMAIL_RECIPIENTS="jakwakwa@gmail.com"
RESEND_FROM_EMAIL="alerts@podzist.com"
ABSA_TEST_EMAIL="absa-test@example.com"
RESEND_SEND_DOMAIN="alerts@podzist.com"
NEXT_PUBLIC_TEST_FORMS=true
TEST_FORMS=true
PROCURECHECK_ENV="sandbox"
PROCURECHECK_SANDBOX_BASE_URL="https://xdev.procurecheck.co.za/api/api/v1/"
PROCURECHECK_BASE_URL="https://api.procurecheck.co.za/api/api/v1/"
PROCURECHECK_EGRESS_OWNER="control-tower-server-runtime"
PROCURECHECK_USERNAME="work@jacofrontend.dev"
PROCURECHECK_PASSWORD=
ENABLE_XDS_ITC="false"
XDS_BASE_URL="http://www.web.xds.co.za/XDSConnectWS"
XDS_USERNAME=
XDS_PASSWORD=
XDS_PRODUCT_ID="41"
XDS_REPORT_ID="18"
OPENSANCTIONS_KEY=
# VAT verification via Firecrawl agent (advisory only, never gates workflow)
ENABLE_FIRECRAWL_VAT_VERIFICATION="false"

# GitHub MCP server (Cursor) — create token at https://github.com/settings/tokens with repo scope
GITHUB_PERSONAL_ACCESS_TOKEN=

# Perimeter Validation Rollout Configuration
ENFORCE_STRICT_SCHEMAS="warn"

# Workflow guardrail bypasses (local debugging only)
# Set true/1/yes/on to skip the initial deny-list re-applicant check.
BYPASS_INITIAL_REAPPLICANT_TEST="false"

# Per-event validation overrides (comma-separated)
# Format: "event1:mode1,event2:mode2"
# Example: "onboarding/lead.created:warn,sanctions/external.received:strict"
PERIMETER_VALIDATION_OVERRIDES=""

# Enable telemetry collection for validation outcomes
PERIMETER_TELEMETRY_ENABLED="true"

# PostHog — app capture (phc_…): either name is fine; used by posthog-js / server capture
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://us.posthog.com
Optional: NEXT_PUBLIC_POSTHOG_HOST, NEXT_PUBLIC_POSTHOG_DEBUG=true, NEXT_PUBLIC_POSTHOG_CAPTURE_EXCEPTIONS=true
Session replay is off unless NEXT_PUBLIC_POSTHOG_SESSION_RECORDING=true
Server batching (avoid one HTTP request per capture): POSTHOG_FLUSH_AT=20 POSTHOG_FLUSH_INTERVAL_MS=10000
# Dev: 
PERIMETER_TELEMETRY_VERBOSE_LOG=true
#  to log every successful perimeter check to the console
#
# PostHog — bootstrap perimeter dashboard script only (phx_… personal key; not the project key above)
# See docs/posthog-perimeter-dashboard.md
POSTHOG_PERSONAL_API_KEY=
POSTHOG_API_HOST=https://us.posthog.com
POSTHOG_PROJECT_ID=349918
# In-app analytics at /dashboard/analytics: optional Clerk user id allowlist (comma-separated) if org:analytics:view is not set up yet
POSTHOG_ANALYTICS_ALLOWED_USER_IDS=
Optional: POSTHOG_PERIMETER_DASHBOARD_NAME="Perimeter validation — Control Tower"
# Optional: POSTHOG_PERIMETER_FORCE_INSIGHTS=1
#  Recommended for day-to-day dev: use REMINDER_FIRST_NUDGE=5s + REMINDER_SECOND_NUDGE=10s in .env.local and trigger manually via the Inngest dev UI.
REMINDER_FIRST_NUDGE=
REMINDER_SECOND_NUDGE=
