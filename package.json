    "@playwright/test": "^1.58.2",
    "@types/bun": "latest",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "inngest-cli": "^1.15.0",
    "typescript": "^5.9.3"
  },
  "trustedDependencies": [
    "inngest-cli"
  ],
  "overrides": {
    "express": "4.20.0",
    "body-parser": "1.20.3",
    "qs": "6.14.1",
    "tar": "7.5.3",
    "axios": "1.12.0"
  }
}