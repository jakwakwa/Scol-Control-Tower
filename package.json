    "@posthog/ai": "^7.12.2",
    "@react-email/components": "^1.0.10",
    "@react-email/render": "^2.0.4",
    "@remixicon/react": "^4.9.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/react-table": "^8.21.3",
    "@tursodatabase/api": "^1.9.2",
    "autoprefixer": "^10.4.27",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.0",
    "drizzle-orm": "^0.45.1",
    "flags": "^4.0.5",
    "framer-motion": "^12.38.0",
    "inngest": "^3.52.7",
    "knip": "^6.2.0",
    "lucide-react": "^0.563.0",
    "md5": "^2.3.0",
    "next": "^16.2.1",
    "next-themes": "^0.4.6",
    "ogl": "^1.0.11",
    "postcss": "^8.5.8",
    "posthog-js": "^1.363.5",
    "posthog-node": "^5.28.5",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.72.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "resend": "^6.9.4",
    "shadcn": "^3.8.5",
    "sonner": "^2.0.7",
    "svix": "^1.89.0",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "use-debounce": "^10.1.0",
    "uuid": "^13.0.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
