{
  "name": "scol-control-tower",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:test": "drizzle-kit migrate --config=drizzle.test.config.ts",
    "db:push:test": "drizzle-kit push --config=drizzle.test.config.ts --force",
    "db:reset": "bun run scripts/db-reset.ts",
    "db:studio": "drizzle-kit studio",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:db:reset": "bun run scripts/reset-test-db.ts",
    "test:db:seed:browser-flow": "bun run scripts/seed-browser-flow-test-data.ts",
    "dev:all": "./setup-dev.sh",
    "dev:browser-flow": "./setup-browser-flow-dev.sh",
    "inngest:dev": "inngest dev",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "docs:install": "bun --cwd docs install",
    "docs:dev": "bun --cwd docs run dev",
    "posthog:perimeter-dashboard": "bun run scripts/posthog/create-perimeter-dashboard.ts",
    "procurecheck:network-check": "curl -s http://localhost:3000/api/integrations/procurecheck/network-check | bun -e 'const r=await Bun.stdin.json();console.log(JSON.stringify(r,null,2))'",
    "test:browser:preflight": "bun run scripts/verify-browser-flow-preflight.ts",
    "test:browser:stage1-3": "bun run test:browser:preflight && bash tests/browser-flow/stage1-3.sh",
    "test:browser:stage4": "bun run test:browser:preflight && bash tests/browser-flow/stage4.sh",
    "test:browser:stage5-6": "bun run test:browser:preflight && bash tests/browser-flow/stage5-6.sh",
    "test:browser-flow-full": "bun run test:browser:preflight && bash tests/browser-flow/stage1-3.sh && bash tests/browser-flow/stage4.sh && bash tests/browser-flow/stage5-6.sh"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
